// MY SOLUTION - Approach 1 (Prefix Sum / Running Left Sum)
var pivotIndex = function(nums) {
    let arrSum = nums.reduce((acc, curr) => acc + curr, 0);
    let leftSum = 0;

    for (let i = 0; i < nums.length; i++) {
        let rightSum = arrSum - leftSum - nums[i];

        if (leftSum === rightSum) {
            return i;
        }

        leftSum += nums[i];
    }

    return -1;
};

// TIME: O(n) — two sequential passes (total + scan), simplifies to O(n)
// SPACE: O(1) — only running variables, no new arrays created